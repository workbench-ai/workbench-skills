{
  "owner_id": "workbench-cli",
  "suite_name": "workbench-cli-hosted",
  "suite_scope": "product-local",
  "submission_schema_version": 1,
  "suite_latency_expectation": {
    "minimum_significant_improvement_ratio": 0.2,
    "notes": "Tasks measure whether an agent can drive the cloud-first CLI and use hosted project commands without relying on private runtime state."
  },
  "evals": [
    {
      "id": "install-or-verify-cli",
      "title": "Verify or install the Workbench CLI",
      "category": "cli_install",
      "prompt": "Set up Workbench CLI access for this repo from scratch. Assume the `workbench` binary is not installed. Install the published CLI, verify the binary, authenticate to `https://v2.workbench.ai`, and report whether hosted setup can continue.",
      "expected_output": "The response uses the Workbench CLI skill, installs the published GitHub Packages CLI only because the binary is missing, verifies the binary, starts the Workbench login flow, and explains that npm package-auth failures should stop setup cleanly.",
      "files": [],
      "required_skills": [
        "workbench-cli"
      ],
      "latency": {
        "baseline_ms": 120000,
        "target_ms": 60000,
        "significant_improvement_ratio": 0.2
      },
      "assertions": [
        {
          "text": "uses the Workbench CLI skill",
          "kind": "includes",
          "path": "skills_used",
          "value": "workbench-cli"
        },
        {
          "text": "configures the Workbench package scope",
          "kind": "matches",
          "path": "tool_commands",
          "value": "npm\\s+config\\s+set\\s+@workbench-ai:registry\\s+https://npm\\.pkg\\.github\\.com"
        },
        {
          "text": "installs the published CLI package",
          "kind": "matches",
          "path": "tool_commands",
          "value": "npm\\s+(?:install|i)\\s+-g\\s+@workbench-ai/workbench-cli\\b"
        },
        {
          "text": "verifies the workbench binary",
          "kind": "matches",
          "path": "tool_commands",
          "value": "(?:^|\\s)(?:workbench\\s+--version|command\\s+-v\\s+workbench)\\b"
        },
        {
          "text": "starts hosted Workbench login",
          "kind": "matches",
          "path": "tool_commands",
          "value": "(?:^|\\s)workbench\\s+login(?:\\s+--base-url\\s+https://v2\\.workbench\\.ai)?\\b"
        },
        {
          "text": "reports install is conditional on a missing binary",
          "kind": "equals",
          "path": "answer.installs_only_when_missing",
          "value": true
        },
        {
          "text": "reports package auth failures stop setup cleanly",
          "kind": "equals",
          "path": "answer.package_auth_failure_stops_setup",
          "value": true
        }
      ]
    },
    {
      "id": "hosted-project-and-spec",
      "title": "Create a hosted project and apply a spec",
      "category": "hosted_spec",
      "prompt": "Create a hosted Workbench project named `invoice-parser`, sync `workbench.yaml` plus local candidate and case snapshots, and report the project id plus the sync result.",
      "expected_output": "The response targets a hosted Workbench server, creates or selects a project with the cloud-first CLI, syncs the local source, and reports hosted project metadata.",
      "files": [],
      "required_skills": [
        "workbench-cli"
      ],
      "latency": {
        "baseline_ms": 150000,
        "target_ms": 75000,
        "significant_improvement_ratio": 0.2
      },
      "assertions": [
        {
          "text": "uses the Workbench CLI skill",
          "kind": "includes",
          "path": "skills_used",
          "value": "workbench-cli"
        },
        {
          "text": "creates a hosted project",
          "kind": "matches",
          "path": "tool_commands",
          "value": "(?:^|\\s)(?:workbench|\\./bin/workbench)\\s+launch\\s+--name\\b"
        },
        {
          "text": "syncs the local source",
          "kind": "matches",
          "path": "tool_commands",
          "value": "(?:^|\\s)(?:workbench|\\./bin/workbench)\\s+sync\\b"
        },
        {
          "text": "reports that hosted project state is durable",
          "kind": "equals",
          "path": "answer.uses_hosted_project_state",
          "value": true
        }
      ]
    },
    {

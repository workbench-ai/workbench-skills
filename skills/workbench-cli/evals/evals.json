        "significant_improvement_ratio": 0.2
      },
      "assertions": [
        {
          "text": "uses the Workbench CLI skill",
          "kind": "includes",
          "path": "skills_used",
          "value": "workbench-cli"
        },
        {
          "text": "routes through the existing-workflow authoring guide",
